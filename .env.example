# ──────────────────────────────────────────
# OpenAI Configuration
# ──────────────────────────────────────────
OPENAI_API_KEY=sk-your-api-key-here

# ──────────────────────────────────────────
# Embedding Model
# ──────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ──────────────────────────────────────────
# LLM Model
# ──────────────────────────────────────────
LLM_MODEL=gpt-4o-mini

# ──────────────────────────────────────────
# Application Settings
# ──────────────────────────────────────────
CHUNK_SIZE=400
CHUNK_OVERLAP=80
SIMILARITY_THRESHOLD=0.45
